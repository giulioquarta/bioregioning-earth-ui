---
export interface Props {
  title?: string;
  description?: string;
}
const { title, description } = Astro.props;
const siteTitle = 'Bioregioning Earth';
const pageTitle = title ? `${title} — ${siteTitle}` : siteTitle;
const base = import.meta.env.BASE_URL;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    {description && <meta name="description" content={description} />}
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Averia+Serif+Libre:ital,wght@0,300;0,400;0,700;1,400&family=Geist:wght@300;400;500;600;700&family=Geist+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <style is:global>
      :root {
        /* ReFi BCN organic theme — Andrea three-pillar lock (260602) */
        --paper-50: #F5F5F5;
        --paper-100: #F1F0EE;
        --paper-200: #DDD7CF;
        --paper-700: #41312A;
        --paper-900: #2A1810;

        --pillar-neural-1: #D9E6FF; --pillar-neural-4: #598FFD; --pillar-neural-6: #2A4A9E;
        --pillar-tissue-1: #E5F5D8; --pillar-tissue-4: #7CB342; --pillar-tissue-6: #2D5016;
        --pillar-flow-1: #F9E2C3; --pillar-flow-4: #F0A030; --pillar-flow-6: #8B5038;

        --bg: var(--paper-50);
        --surface: var(--paper-100);
        --card: #FFFFFF;
        --border: var(--paper-200);
        --fg: var(--paper-900);
        --muted: var(--paper-700);
        --primary: var(--pillar-flow-4);
        --primary-hover: var(--pillar-flow-6);
        --primary-fg: var(--paper-900);
        --accent: var(--pillar-neural-1);
        --accent-fg: var(--pillar-neural-6);
        --success: #214033;
        --info: #598FFD;

        --radius: 0.5rem;
        --radius-sm: 0.25rem;
        --radius-pill: 9999px;
        --max-w: 1280px;

        --sans: "Geist", system-ui, -apple-system, "Segoe UI", sans-serif;
        --serif: "Averia Serif Libre", Georgia, serif;
        --mono: "Geist Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
      }
      * { box-sizing: border-box; }
      html, body {
        margin: 0;
        padding: 0;
        background: var(--bg);
        color: var(--fg);
        font-family: var(--sans);
        line-height: 1.55;
      }
      a { color: var(--primary); text-decoration: none; }
      a:hover { text-decoration: underline; }
      ::selection { background: var(--accent); color: var(--fg); }
    </style>
  </head>
  <body>
    <nav style="position:sticky;top:0;z-index:50;background:rgba(245,245,245,0.92);backdrop-filter:blur(12px);border-bottom:1px solid var(--border);">
      <div style="max-width:var(--max-w);margin:0 auto;padding:0 1.5rem;display:flex;align-items:center;justify-content:space-between;height:56px;gap:1rem;">
        <a href={`${base}/`} style="font-weight:600;font-size:1.05rem;color:var(--fg);white-space:nowrap;font-family:var(--serif);">🌱 {siteTitle}</a>
        <div style="display:flex;gap:1.25rem;flex-wrap:wrap;justify-content:flex-end;align-items:center;font-family:var(--mono);font-size:0.75rem;text-transform:uppercase;letter-spacing:0.04em;">
          <a href={`${base}/map`} style="color:var(--primary);font-weight:500;">Map</a>
          <span style="color:var(--border);">|</span>
          <a href={`${base}/organizations`} style="color:var(--muted);">Organizations</a>
          <a href={`${base}/sources`} style="color:var(--muted);">Sources</a>
          <a href={`${base}/ontology`} style="color:var(--muted);">Ontology</a>
        </div>
      </div>
    </nav>
    <slot />
    <footer style="border-top:1px solid var(--border);margin-top:4rem;padding:2rem 1.5rem;text-align:center;color:var(--muted);font-size:0.8rem;font-family:var(--mono);text-transform:uppercase;letter-spacing:0.04em;">
      <div style="max-width:var(--max-w);margin:0 auto;">
        Bioregioning Earth — Powered by Notion + Astro
      </div>
    </footer>
  </body>
</html>
