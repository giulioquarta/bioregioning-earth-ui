---
import Layout from '../../layouts/Layout.astro';
import NetworkSection from '../../components/NetworkSection.astro';
import { loadSectionConfig, fetchSectionRecords } from '../../lib/notion';

export async function getStaticPaths() {
  const sections = loadSectionConfig();
  return sections.map((s) => ({
    params: { section: s.route.replace(/^\//, '') },
    props: { section: s },
  }));
}

const { section } = Astro.props;
const records = await fetchSectionRecords(section);
const base = import.meta.env.BASE_URL;

function hasCoords(props: Record<string, any>): boolean {
  for (const key of Object.keys(props)) {
    const val = props[key];
    if (val && typeof val === 'object' && !Array.isArray(val)) {
      const hasLat = val.latitude != null && val.latitude !== '';
      const hasLng = val.longitude != null && val.longitude !== '';
      if (hasLat && hasLng) {
        const lat = Number(val.latitude);
        const lng = Number(val.longitude);
        if (!isNaN(lat) && !isNaN(lng)) return true;
      }
    }
  }
  const lat = Number(
    props['Lat'] ?? props['lat'] ?? props['Latitude'] ?? props['latitude'] ??
    props['location_lat'] ?? props['location_Lat'] ?? props['Location_Lat']
  );
  const lng = Number(
    props['Lng'] ?? props['lng'] ?? props['Longitude'] ?? props['longitude'] ??
    props['location_lng'] ?? props['location_Lng'] ?? props['Location_Lng']
  );
  return !isNaN(lat) && !isNaN(lng) && (lat !== 0 || lng !== 0);
}

function getTitle(r: any): string {
  return String(r.properties['Name'] ?? r.properties['Title'] ?? r.properties['name'] ?? r.properties['title'] ?? 'Untitled');
}

function getType(r: any): string {
  return String(r.properties['Type'] ?? r.properties['type'] ?? r.properties['Tags']?.[0] ?? r.properties['tags']?.[0] ?? '');
}

function getLocation(r: any): string {
  return String(
    r.properties['Scope'] ?? r.properties['scope'] ??
    r.properties['Comarca'] ?? r.properties['comarca'] ??
    r.properties['Place']?.address ??
    ''
  );
}

function getDescription(r: any): string {
  return String(r.properties['Description'] ?? r.properties['description'] ?? '');
}

function getUrl(r: any): string | null {
  return r.properties['URL'] ?? r.properties['Url'] ?? r.properties['url'] ?? r.properties['Website'] ?? r.properties['website'] ?? null;
}

const hasMapData = records.some((r) => hasCoords(r.properties));
const isOrgs = section.id === 'bioregional-organizations';

// Build markers with full panel data
const markers = records
  .map((r) => {
    const props = r.properties ?? {};
    let lat: number | null = null;
    let lng: number | null = null;

    for (const key of Object.keys(props)) {
      const val = props[key];
      if (val && typeof val === 'object' && !Array.isArray(val) && 'latitude' in val && 'longitude' in val) {
        const lt = Number(val.latitude);
        const ln = Number(val.longitude);
        if (!isNaN(lt) && !isNaN(ln)) { lat = lt; lng = ln; }
      }
    }
    if (lat === null) {
      const nLat = Number(props['Lat'] ?? props['lat'] ?? props['Latitude'] ?? props['latitude'] ?? props['location_lat'] ?? props['location_Lat'] ?? props['Location_Lat']);
      const nLng = Number(props['Lng'] ?? props['lng'] ?? props['Longitude'] ?? props['longitude'] ?? props['location_lng'] ?? props['location_Lng'] ?? props['Location_Lng']);
      if (!isNaN(nLat) && !isNaN(nLng) && (nLat !== 0 || nLng !== 0)) { lat = nLat; lng = nLng; }
    }
    if (lat === null) return null;

    const slug = r.id.replace(/-/g, '');
    return {
      id: r.id,
      slug,
      lat,
      lng,
      name: getTitle(r),
      type: getType(r),
      location: getLocation(r),
      description: getDescription(r),
      url: getUrl(r),
      href: `${base}${section.route}/${slug}`,
    };
  })
  .filter(Boolean);
---

<Layout title={section.name} description={section.description}>
  <main style="max-width:var(--max-w);margin:0 auto;padding:2rem 1.5rem;">
    <a href={`${base}/`} style="display:inline-block;font-size:0.8rem;color:var(--muted);margin-bottom:1.25rem;text-decoration:none;font-family:var(--mono);text-transform:uppercase;letter-spacing:0.04em;">← Back to Dashboard</a>

    <header style="margin-bottom:2rem;">
      <h1 style="font-size:clamp(1.6rem, 3.2vw, 2.2rem);font-weight:500;margin:0 0 0.5rem 0;color:var(--fg);font-family:var(--sans);letter-spacing:-0.01em;">{section.name}</h1>
      <p style="color:var(--muted);margin:0;font-size:1rem;max-width:640px;">{section.description}</p>
      <p style="color:var(--muted);margin:0.75rem 0 0 0;font-size:0.8rem;font-family:var(--mono);text-transform:uppercase;letter-spacing:0.04em;">{records.length} records</p>
    </header>

    {hasMapData && isOrgs && (
      <section style="margin-bottom:2.5rem;position:relative;">
        <div id="org-map" style="width:100%;height:480px;border-radius:var(--radius);overflow:hidden;border:1px solid var(--border);" data-markers={JSON.stringify(markers)}></div>

        <!-- Side panel -->
        <div
          id="org-panel"
          style="display:none;position:absolute;top:0.5rem;right:0.5rem;bottom:0.5rem;width:320px;max-width:calc(100% - 1rem);background:rgba(255,255,255,0.97);backdrop-filter:blur(12px);border:1px solid var(--border);border-radius:var(--radius);padding:1.25rem;z-index:20;overflow-y:auto;box-shadow:0 8px 32px rgba(42,24,16,0.12);"
        >
          <button
            id="org-panel-close"
            style="position:absolute;top:0.75rem;right:0.75rem;background:none;border:none;color:var(--muted);font-size:1.2rem;cursor:pointer;line-height:1;"
            aria-label="Close panel"
          >✕</button>
          <div id="org-panel-content"></div>
        </div>

        <script>
          import maplibregl from 'maplibre-gl';
          import 'maplibre-gl/dist/maplibre-gl.css';

          function initMap() {
            const container = document.getElementById('org-map');
            if (!container) return;

            const raw = container.dataset.markers || '[]';
            const markers = JSON.parse(raw);
            if (markers.length === 0) return;

            const avgLat = markers.reduce((s, m) => s + m.lat, 0) / markers.length;
            const avgLng = markers.reduce((s, m) => s + m.lng, 0) / markers.length;

            const map = new maplibregl.Map({
              container,
              style: {
                version: 8,
                sources: {
                  osm: {
                    type: 'raster',
                    tiles: ['https://tile.openstreetmap.org/{z}/{x}/{y}.png'],
                    tileSize: 256,
                    attribution: '&copy; OpenStreetMap contributors',
                  },
                },
                layers: [{ id: 'osm', type: 'raster', source: 'osm' }],
              },
              center: [avgLng || 0, avgLat || 20],
              zoom: markers.length === 1 ? 4 : 2,
            });

            map.addControl(new maplibregl.NavigationControl(), 'top-right');

            const bounds = new maplibregl.LngLatBounds();
            const panel = document.getElementById('org-panel');
            const panelContent = document.getElementById('org-panel-content');
            const panelClose = document.getElementById('org-panel-close');

            function showPanel(m) {
              if (!panel || !panelContent) return;
              const urlHtml = m.url ? `<p style="margin:0.5rem 0 0 0;font-size:0.8rem;font-family:var(--mono);word-break:break-all;"><a href="${m.url}" target="_blank" rel="noopener" style="color:var(--primary);">${m.url}</a></p>` : '';
              const descHtml = m.description ? `<p style="margin:0.75rem 0 0 0;font-size:0.9rem;color:var(--fg);line-height:1.55;">${m.description}</p>` : '';
              panelContent.innerHTML = `
                <h3 style="margin:0 0 0.35rem 0;font-size:1.1rem;font-weight:600;color:var(--fg);font-family:var(--sans);padding-right:1.5rem;">${m.name}</h3>
                <div style="display:flex;gap:0.4rem;flex-wrap:wrap;margin-bottom:0.5rem;">
                  ${m.type ? `<span style="font-size:0.72rem;padding:0.15rem 0.5rem;border-radius:var(--radius-pill);background:var(--accent);color:var(--accent-fg);font-family:var(--mono);text-transform:uppercase;letter-spacing:0.02em;">${m.type}</span>` : ''}
                  ${m.location ? `<span style="font-size:0.72rem;padding:0.15rem 0.5rem;border-radius:var(--radius-pill);background:var(--surface);color:var(--muted);font-family:var(--mono);text-transform:uppercase;letter-spacing:0.02em;">${m.location}</span>` : ''}
                </div>
                ${descHtml}
                ${urlHtml}
                <div style="margin-top:1rem;">
                  <a href="${m.href}" style="display:inline-block;padding:0.45rem 0.9rem;border-radius:var(--radius);background:var(--primary);color:var(--primary-fg);font-size:0.8rem;text-decoration:none;font-family:var(--mono);text-transform:uppercase;letter-spacing:0.03em;">View full page →</a>
                </div>
              `;
              panel.style.display = 'block';
            }

            function hidePanel() {
              if (panel) panel.style.display = 'none';
            }

            panelClose?.addEventListener('click', hidePanel);

            for (const m of markers) {
              const el = document.createElement('div');
              // Flex wrapper so tooltip centers without CSS transform (avoids MapLibre disappearing bug)
              el.style.cssText = 'width:max-content;min-width:16px;height:16px;display:flex;align-items:flex-end;justify-content:center;position:relative;cursor:pointer;';

              const dot = document.createElement('div');
              dot.style.cssText = 'width:16px;height:16px;border-radius:50%;background:var(--primary);border:2px solid var(--fg);box-shadow:0 2px 6px rgba(0,0,0,0.25);flex-shrink:0;';
              el.appendChild(dot);

              // Tooltip on hover (no transform)
              const tooltip = document.createElement('div');
              tooltip.textContent = m.name;
              tooltip.style.cssText = 'position:absolute;bottom:20px;left:0;right:0;width:max-content;margin:0 auto;background:var(--fg);color:var(--paper-50);padding:0.3rem 0.6rem;border-radius:var(--radius-sm);font-size:0.75rem;font-family:var(--sans);white-space:nowrap;pointer-events:none;opacity:0;transition:opacity 0.15s;z-index:30;';
              el.appendChild(tooltip);

              el.addEventListener('mouseenter', () => { tooltip.style.opacity = '1'; });
              el.addEventListener('mouseleave', () => { tooltip.style.opacity = '0'; });

              el.addEventListener('click', (e) => {
                e.stopPropagation();
                showPanel(m);
              });

              new maplibregl.Marker({ element: el })
                .setLngLat([m.lng, m.lat])
                .addTo(map);

              bounds.extend([m.lng, m.lat]);
            }

            if (markers.length > 1) {
              map.fitBounds(bounds, { padding: 40, maxZoom: 8 });
            }

            // Click map background to close panel
            map.on('click', hidePanel);
          }

          if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', initMap);
          } else {
            initMap();
          }
        </script>
      </section>
    )}

    {hasMapData && !isOrgs && (
      <section style="margin-bottom:2.5rem;">
        <div id="section-map" style="width:100%;height:480px;border-radius:var(--radius);overflow:hidden;border:1px solid var(--border);" data-markers={JSON.stringify(
          records
            .filter((r) => hasCoords(r.properties))
            .map((r) => {
              const props = r.properties ?? {};
              let lat = null, lng = null;
              for (const key of Object.keys(props)) {
                const val = props[key];
                if (val && typeof val === 'object' && !Array.isArray(val) && 'latitude' in val && 'longitude' in val) {
                  const lt = Number(val.latitude); const ln = Number(val.longitude);
                  if (!isNaN(lt) && !isNaN(ln)) { lat = lt; lng = ln; }
                }
              }
              if (lat === null) {
                const nLat = Number(props['Lat'] ?? props['lat'] ?? props['Latitude'] ?? props['latitude'] ?? props['location_lat'] ?? props['location_Lat'] ?? props['Location_Lat']);
                const nLng = Number(props['Lng'] ?? props['lng'] ?? props['Longitude'] ?? props['longitude'] ?? props['location_lng'] ?? props['location_Lng'] ?? props['Location_Lng']);
                if (!isNaN(nLat) && !isNaN(nLng) && (nLat !== 0 || nLng !== 0)) { lat = nLat; lng = nLng; }
              }
              if (lat === null) return null;
              const slug = r.id.replace(/-/g, '');
              return { lat, lng, name: getTitle(r), link: `${base}${section.route}/${slug}` };
            })
            .filter(Boolean)
        )}></div>
        <script>
          import maplibregl from 'maplibre-gl';
          import 'maplibre-gl/dist/maplibre-gl.css';
          function initSimpleMap() {
            const container = document.getElementById('section-map');
            if (!container) return;
            const markers = JSON.parse(container.dataset.markers || '[]');
            if (markers.length === 0) return;
            const avgLat = markers.reduce((s, m) => s + m.lat, 0) / markers.length;
            const avgLng = markers.reduce((s, m) => s + m.lng, 0) / markers.length;
            const map = new maplibregl.Map({
              container,
              style: {
                version: 8,
                sources: { osm: { type: 'raster', tiles: ['https://tile.openstreetmap.org/{z}/{x}/{y}.png'], tileSize: 256, attribution: '&copy; OpenStreetMap contributors' } },
                layers: [{ id: 'osm', type: 'raster', source: 'osm' }],
              },
              center: [avgLng || 0, avgLat || 20],
              zoom: markers.length === 1 ? 4 : 2,
            });
            map.addControl(new maplibregl.NavigationControl(), 'top-right');
            const bounds = new maplibregl.LngLatBounds();
            for (const m of markers) {
              const el = document.createElement('div');
              el.style.cssText = 'width:14px;height:14px;border-radius:50%;background:var(--primary);border:2px solid var(--fg);box-shadow:0 2px 6px rgba(0,0,0,0.2);cursor:pointer;';
              const popup = new maplibregl.Popup({ offset: 8, closeButton: false }).setHTML(
                `<a href="${m.link}" style="font-weight:600;font-size:0.9rem;color:var(--primary);text-decoration:none;font-family:var(--sans);">${m.name}</a>`
              );
              new maplibregl.Marker({ element: el }).setLngLat([m.lng, m.lat]).setPopup(popup).addTo(map);
              bounds.extend([m.lng, m.lat]);
            }
            if (markers.length > 1) map.fitBounds(bounds, { padding: 40, maxZoom: 8 });
          }
          if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', initSimpleMap);
          else initSimpleMap();
        </script>
      </section>
    )}

    <!-- Table view for Organizations -->
    {isOrgs && (
      <section style="margin-bottom:2.5rem;">
        <div style="overflow-x:auto;border:1px solid var(--border);border-radius:var(--radius);background:var(--card);">
          <table style="width:100%;border-collapse:collapse;font-size:0.9rem;">
            <thead>
              <tr style="border-bottom:1px solid var(--border);background:var(--surface);">
                <th style="text-align:left;padding:0.75rem 1rem;font-family:var(--mono);font-size:0.7rem;text-transform:uppercase;letter-spacing:0.05em;color:var(--muted);font-weight:500;">Name</th>
                <th style="text-align:left;padding:0.75rem 1rem;font-family:var(--mono);font-size:0.7rem;text-transform:uppercase;letter-spacing:0.05em;color:var(--muted);font-weight:500;">Type</th>
                <th style="text-align:left;padding:0.75rem 1rem;font-family:var(--mono);font-size:0.7rem;text-transform:uppercase;letter-spacing:0.05em;color:var(--muted);font-weight:500;">Location</th>
                <th style="text-align:left;padding:0.75rem 1rem;font-family:var(--mono);font-size:0.7rem;text-transform:uppercase;letter-spacing:0.05em;color:var(--muted);font-weight:500;">Link</th>
              </tr>
            </thead>
            <tbody>
              {records.map((r) => {
                const slug = r.id.replace(/-/g, '');
                const href = `${base}${section.route}/${slug}`;
                return (
                  <tr style="border-bottom:1px solid var(--border);transition:background 0.12s;" onmouseenter="this.style.background='var(--surface)'" onmouseleave="this.style.background=''">
                    <td style="padding:0.6rem 1rem;color:var(--fg);font-weight:500;">
                      <a href={href} style="color:var(--fg);text-decoration:none;">{getTitle(r)}</a>
                    </td>
                    <td style="padding:0.6rem 1rem;color:var(--muted);">{getType(r)}</td>
                    <td style="padding:0.6rem 1rem;color:var(--muted);">{getLocation(r)}</td>
                    <td style="padding:0.6rem 1rem;">
                      <a href={href} style="color:var(--primary);font-family:var(--mono);font-size:0.75rem;text-transform:uppercase;letter-spacing:0.03em;">View →</a>
                    </td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      </section>
    )}

    <!-- Card view for non-Orgs -->
    {!isOrgs && <NetworkSection records={records} basePath={section.route} />}
  </main>
</Layout>
