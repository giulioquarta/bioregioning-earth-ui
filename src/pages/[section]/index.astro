---
import Layout from '../../layouts/Layout.astro';
import NetworkSection from '../../components/NetworkSection.astro';
import OntologyGallery from '../../components/OntologyGallery.astro';
import SourcesTable from '../../components/SourcesTable.astro';
import OrganizationsTable from '../../components/OrganizationsTable.astro';
import EarthMap from '../../components/EarthMap.astro';
import { loadSectionConfig, fetchSectionRecords } from '../../lib/notion';

export async function getStaticPaths() {
  const sections = loadSectionConfig();
  return sections.map((s) => ({
    params: { section: s.route.replace(/^\//, '') },
    props: { section: s },
  }));
}

const { section } = Astro.props;
const records = await fetchSectionRecords(section);
const base = import.meta.env.BASE_URL;

function hasCoords(props: Record<string, any>): boolean {
  for (const key of Object.keys(props)) {
    const val = props[key];
    if (val && typeof val === 'object' && !Array.isArray(val)) {
      const hasLat = val.latitude != null && val.latitude !== '';
      const hasLng = val.longitude != null && val.longitude !== '';
      if (hasLat && hasLng) {
        const lat = Number(val.latitude);
        const lng = Number(val.longitude);
        if (!isNaN(lat) && !isNaN(lng)) return true;
      }
    }
  }
  const lat = Number(
    props['Lat'] ?? props['lat'] ?? props['Latitude'] ?? props['latitude'] ??
    props['location_lat'] ?? props['location_Lat'] ?? props['Location_Lat']
  );
  const lng = Number(
    props['Lng'] ?? props['lng'] ?? props['Longitude'] ?? props['longitude'] ??
    props['location_lng'] ?? props['location_Lng'] ?? props['Location_Lng']
  );
  return !isNaN(lat) && !isNaN(lng) && (lat !== 0 || lng !== 0);
}

function getTitle(r: any): string {
  return String(r.properties['Name'] ?? r.properties['Title'] ?? r.properties['name'] ?? r.properties['title'] ?? 'Untitled');
}

function getType(r: any): string {
  return String(r.properties['Type'] ?? r.properties['type'] ?? r.properties['Tags']?.[0] ?? r.properties['tags']?.[0] ?? '');
}

function getLocation(r: any): string {
  return String(
    r.properties['Scope'] ?? r.properties['scope'] ??
    r.properties['Comarca'] ?? r.properties['comarca'] ??
    r.properties['Place']?.address ??
    ''
  );
}

function getDescription(r: any): string {
  return String(r.properties['Description'] ?? r.properties['description'] ?? '');
}

function getUrl(r: any): string | null {
  return r.properties['URL'] ?? r.properties['Url'] ?? r.properties['url'] ?? r.properties['Website'] ?? r.properties['website'] ?? null;
}

const hasMapData = records.some((r) => hasCoords(r.properties));
const isOrgs = section.id === 'bioregional-organizations';
const isOntology = section.id === 'ontology';
const isSources = section.id === 'sources';

// Build markers with full panel data
const markers = records
  .map((r) => {
    const props = r.properties ?? {};
    let lat: number | null = null;
    let lng: number | null = null;

    for (const key of Object.keys(props)) {
      const val = props[key];
      if (val && typeof val === 'object' && !Array.isArray(val) && 'latitude' in val && 'longitude' in val) {
        const lt = Number(val.latitude);
        const ln = Number(val.longitude);
        if (!isNaN(lt) && !isNaN(ln)) { lat = lt; lng = ln; }
      }
    }
    if (lat === null) {
      const nLat = Number(props['Lat'] ?? props['lat'] ?? props['Latitude'] ?? props['latitude'] ?? props['location_lat'] ?? props['location_Lat'] ?? props['Location_Lat']);
      const nLng = Number(props['Lng'] ?? props['lng'] ?? props['Longitude'] ?? props['longitude'] ?? props['location_lng'] ?? props['location_Lng'] ?? props['Location_Lng']);
      if (!isNaN(nLat) && !isNaN(nLng) && (nLat !== 0 || nLng !== 0)) { lat = nLat; lng = nLng; }
    }
    if (lat === null) return null;

    const slug = r.id.replace(/-/g, '');
    return {
      id: r.id,
      slug,
      lat,
      lng,
      name: getTitle(r),
      type: getType(r),
      location: getLocation(r),
      description: getDescription(r),
      url: getUrl(r),
      href: `${base}${section.route}/${slug}`,
    };
  })
  .filter(Boolean);
---

<Layout title={section.name} description={section.description}>
  <main style="max-width:var(--max-w);margin:0 auto;padding:2rem 1.5rem;">
    <a href={`${base}/`} style="display:inline-block;font-size:0.8rem;color:var(--muted);margin-bottom:1.25rem;text-decoration:none;font-family:var(--mono);text-transform:uppercase;letter-spacing:0.04em;">← Back to Dashboard</a>

    <header style="margin-bottom:2rem;">
      <h1 style="font-size:clamp(1.6rem, 3.2vw, 2.2rem);font-weight:500;margin:0 0 0.5rem 0;color:var(--fg);font-family:var(--sans);letter-spacing:-0.01em;">{section.name}</h1>
      <p style="color:var(--muted);margin:0;font-size:1rem;max-width:640px;">{section.description}</p>
      <p style="color:var(--muted);margin:0.75rem 0 0 0;font-size:0.8rem;font-family:var(--mono);text-transform:uppercase;letter-spacing:0.04em;">{records.length} records</p>
    </header>

    {hasMapData && (
      <section style="margin-bottom:2.5rem;">
        <EarthMap records={records} basePath={section.route} />
      </section>
    )}

    <!-- Table view for Organizations -->
    {isOrgs && (
      <section style="margin-bottom:2.5rem;">
        <OrganizationsTable records={records} basePath={section.route} />
      </section>
    )}

    <!-- Section-specific views -->
    {isOntology && <OntologyGallery records={records} basePath={section.route} />}
    {isSources && <SourcesTable records={records} basePath={section.route} />}
    {!isOrgs && !isOntology && !isSources && <NetworkSection records={records} basePath={section.route} />}
  </main>
</Layout>
