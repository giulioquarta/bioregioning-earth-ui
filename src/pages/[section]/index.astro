---
import Layout from '../../layouts/Layout.astro';
import EarthMap from '../../components/EarthMap.astro';
import NetworkSection from '../../components/NetworkSection.astro';
import { loadSectionConfig, fetchSectionRecords } from '../../lib/notion';

export async function getStaticPaths() {
  const sections = loadSectionConfig();
  return sections.map((s) => ({
    params: { section: s.route.replace(/^\//, '') },
    props: { section: s },
  }));
}

const { section } = Astro.props;
const records = await fetchSectionRecords(section);
const base = import.meta.env.BASE_URL;

const hasMapData = records.some((r) => {
  const lat = Number(r.properties['Lat'] ?? r.properties['lat'] ?? r.properties['Latitude']);
  const lng = Number(r.properties['Lng'] ?? r.properties['lng'] ?? r.properties['Longitude']);
  return !isNaN(lat) && !isNaN(lng);
});
---

<Layout title={section.name} description={section.description}>
  <main style="max-width:var(--max-w);margin:0 auto;padding:2rem 1.5rem;">
    <a href={`${base}/`} style="display:inline-block;font-size:0.85rem;color:var(--muted);margin-bottom:1.25rem;text-decoration:none;">← Back to Dashboard</a>

    <header style="margin-bottom:2rem;">
      <h1 style="font-size:2rem;font-weight:700;margin:0 0 0.5rem 0;color:var(--fg);">{section.name}</h1>
      <p style="color:var(--muted);margin:0;font-size:1rem;max-width:640px;">{section.description}</p>
      <p style="color:var(--muted);margin:0.75rem 0 0 0;font-size:0.9rem;">{records.length} records</p>
    </header>

    {hasMapData && (
      <section style="margin-bottom:2.5rem;">
        <EarthMap records={records} basePath={section.route} />
      </section>
    )}

    <NetworkSection records={records} basePath={section.route} />
  </main>
</Layout>
