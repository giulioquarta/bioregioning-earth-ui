---
import Layout from '../../layouts/Layout.astro';
import { loadSectionConfig, fetchSectionRecords } from '../../lib/notion';
import type { NormalizedRecord } from '../../lib/notion';

export async function getStaticPaths() {
  const sections = loadSectionConfig();
  const allPaths: { params: { section: string; slug: string }; props: { record: NormalizedRecord; sectionRoute: string; sectionName: string } }[] = [];

  for (const section of sections) {
    if (!section.database_id) continue;
    const records = await fetchSectionRecords(section);
    for (const r of records) {
      allPaths.push({
        params: {
          section: section.route.replace(/^\//, ''),
          slug: r.id.replace(/-/g, ''),
        },
        props: { record: r, sectionRoute: section.route, sectionName: section.name },
      });
    }
  }

  return allPaths;
}

interface Props {
  record: NormalizedRecord;
  sectionRoute: string;
  sectionName: string;
}

const { record, sectionRoute, sectionName } = Astro.props;
const base = import.meta.env.BASE_URL;

function getTitle(r: NormalizedRecord): string {
  return String(r.properties['Name'] ?? r.properties['Title'] ?? r.properties['name'] ?? r.properties['title'] ?? 'Untitled');
}

function getDescription(r: NormalizedRecord): string {
  return String(r.properties['Description'] ?? r.properties['description'] ?? r.properties['Notes'] ?? r.properties['notes'] ?? '');
}

const title = getTitle(record);
const description = getDescription(record).slice(0, 200);
---

<Layout title={title} description={description}>
  <main style="max-width:720px;margin:0 auto;padding:2rem 1.5rem;">
    <div style="margin-bottom:1.5rem;">
      <a href={`${base}${sectionRoute}`} style="font-size:0.85rem;color:var(--muted);text-decoration:none;">← {sectionName}</a>
    </div>

    <h1 style="font-size:2rem;font-weight:700;margin:0 0 1rem 0;color:var(--fg);line-height:1.2;">{title}</h1>

    {description && (
      <p style="font-size:1.05rem;color:var(--fg);line-height:1.6;margin:0 0 1.5rem 0;">{description}</p>
    )}

    <div style="border-radius:var(--radius);border:1px solid var(--border);background:var(--card);padding:1.5rem;margin-bottom:1.5rem;">
      <dl style="display:grid;grid-template-columns:1fr;gap:1rem;margin:0;">
        {Object.entries(record.properties).map(([key, value]) => {
          if (value === null || value === undefined || value === '' || (Array.isArray(value) && value.length === 0)) return null;
          return (
            <div style="display:grid;grid-template-columns:140px 1fr;gap:0.75rem;align-items:start;">
              <dt style="font-size:0.75rem;color:var(--muted);text-transform:uppercase;letter-spacing:0.05em;padding-top:0.15rem;">{key}</dt>
              <dd style="margin:0;font-size:0.9rem;color:var(--fg);word-break:break-word;">
                {Array.isArray(value) ? value.join(', ') : String(value)}
              </dd>
            </div>
          );
        })}
      </dl>
    </div>

    <div style="display:flex;gap:1rem;flex-wrap:wrap;">
      <a href={record.url} target="_blank" rel="noopener noreferrer" style="display:inline-block;padding:0.6rem 1.2rem;border-radius:var(--radius);background:var(--surface);color:var(--accent);border:1px solid var(--border);font-size:0.9rem;text-decoration:none;transition:background 0.15s;" onmouseenter="this.style.background='var(--border)'" onmouseleave="this.style.background='var(--surface)'">
        View in Notion →
      </a>
      <a href={`${base}${sectionRoute}`} style="display:inline-block;padding:0.6rem 1.2rem;border-radius:var(--radius);color:var(--muted);font-size:0.9rem;text-decoration:none;">
        ← Back to {sectionName}
      </a>
    </div>
  </main>
</Layout>
