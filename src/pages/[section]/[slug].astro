---
import Layout from '../../layouts/Layout.astro';
import OrgDetail from '../../components/OrgDetail.astro';
import { loadSectionConfig, loadRelatedDatabases, fetchSectionRecords, fetchDatabaseRecords, fetchActivitiesRecords, buildRecordMap } from '../../lib/notion';
import type { NormalizedRecord } from '../../lib/notion';

export async function getStaticPaths() {
  const sections = loadSectionConfig();
  const related = loadRelatedDatabases();

  const orgSection = sections.find((s) => s.id === 'bioregional-organizations');
  const sourcesSection = sections.find((s) => s.id === 'sources');
  const ontologySection = sections.find((s) => s.id === 'ontology');

  const [allOrgs, allSources, allOntology, allActivities] = await Promise.all([
    orgSection?.database_id ? fetchDatabaseRecords(orgSection.database_id) : Promise.resolve([]),
    sourcesSection?.database_id ? fetchDatabaseRecords(sourcesSection.database_id) : Promise.resolve([]),
    ontologySection?.database_id ? fetchDatabaseRecords(ontologySection.database_id) : Promise.resolve([]),
    related.activities ? fetchActivitiesRecords() : Promise.resolve([]),
  ]);

  const allPaths: {
    params: { section: string; slug: string };
    props: {
      record: NormalizedRecord;
      sectionRoute: string;
      sectionName: string;
      lookups: {
        tags: Map<string, NormalizedRecord>;
        activities: Map<string, NormalizedRecord>;
        sources: Map<string, NormalizedRecord>;
        affiliations: Map<string, NormalizedRecord>;
      };
    };
  }[] = [];

  for (const section of sections) {
    if (!section.database_id) continue;
    const records = await fetchSectionRecords(section);
    for (const r of records) {
      allPaths.push({
        params: {
          section: section.route.replace(/^\//, ''),
          slug: r.id.replace(/-/g, ''),
        },
        props: {
          record: r,
          sectionRoute: section.route,
          sectionName: section.name,
          lookups: {
            tags: buildRecordMap(allOntology),
            activities: buildRecordMap(allActivities),
            sources: buildRecordMap(allSources),
            affiliations: buildRecordMap(allOrgs),
          },
        },
      });
    }
  }

  return allPaths;
}

interface Props {
  record: NormalizedRecord;
  sectionRoute: string;
  sectionName: string;
  lookups: {
    tags: Map<string, NormalizedRecord>;
    activities: Map<string, NormalizedRecord>;
    sources: Map<string, NormalizedRecord>;
    affiliations: Map<string, NormalizedRecord>;
  };
}

const { record, sectionRoute, sectionName, lookups } = Astro.props;
const base = import.meta.env.BASE_URL;
const isOrgs = sectionRoute === '/organizations';

const title = record.properties['Name']?.toString() ?? record.properties['Title']?.toString() ?? 'Untitled';
const description = (record.properties['Description']?.toString() ?? record.properties['description']?.toString() ?? '').slice(0, 200);
---

<Layout title={title} description={description}>
  <main style="max-width:720px;margin:0 auto;padding:2rem 1.5rem;">
    <div style="margin-bottom:1.5rem;">
      <a href={`${base}${sectionRoute}`} style="font-size:0.8rem;color:var(--muted);text-decoration:none;font-family:var(--mono);text-transform:uppercase;letter-spacing:0.04em;">← {sectionName}</a>
    </div>

    <div style="border-radius:var(--radius);border:1px solid var(--border);background:var(--card);padding:1.5rem;margin-bottom:1.5rem;">
      {isOrgs ? (
        <OrgDetail record={record} lookups={lookups} mode="page" />
      ) : (
        <dl style="display:grid;grid-template-columns:1fr;gap:1rem;margin:0;">
          {Object.entries(record.properties).map(([key, value]) => {
            if (value === null || value === undefined || value === '' || (Array.isArray(value) && value.length === 0)) return null;
            const keyLower = key.toLowerCase();
            if (['source_file', 'id', 'location_lat', 'location_lng', 'name'].includes(keyLower)) return null;
            if (typeof value === 'object' && 'latitude' in value && 'longitude' in value && !('address' in value && value.address)) return null;
            const display = Array.isArray(value) ? value.join(', ') :
              typeof value === 'object' ? (value.address ?? value.name ?? JSON.stringify(value)) : String(value);
            return (
              <div style="display:grid;grid-template-columns:140px 1fr;gap:0.75rem;align-items:start;">
                <dt style="font-size:0.7rem;color:var(--muted);text-transform:uppercase;letter-spacing:0.06em;padding-top:0.15rem;font-family:var(--mono);">{key}</dt>
                <dd style="margin:0;font-size:0.9rem;color:var(--fg);word-break:break-word;">{display}</dd>
              </div>
            );
          })}
        </dl>
      )}
    </div>

    <div style="display:flex;gap:1rem;flex-wrap:wrap;">
      <a href={`${base}${sectionRoute}`} style="display:inline-block;padding:0.6rem 1.2rem;border-radius:var(--radius);color:var(--muted);font-size:0.85rem;text-decoration:none;font-family:var(--mono);text-transform:uppercase;letter-spacing:0.04em;">
        ← Back to {sectionName}
      </a>
    </div>
  </main>
</Layout>
