---
import Layout from '../layouts/Layout.astro';
import EarthMap from '../components/EarthMap.astro';
import NetworkSection from '../components/NetworkSection.astro';
import { loadSectionConfig, fetchSectionRecords } from '../lib/notion';

const sections = loadSectionConfig();
const base = import.meta.env.BASE_URL;

const sectionsWithData = await Promise.all(
  sections.map(async (s) => {
    const records = await fetchSectionRecords(s);
    return { section: s, records };
  })
);

const totalRecords = sectionsWithData.reduce((sum, { records }) => sum + records.length, 0);

// For dashboard map: include section route with each record so markers link correctly
const mapMarkers = sectionsWithData.flatMap(({ section, records }) =>
  records.map(r => ({ ...r, sectionRoute: section.route }))
);

function hasCoords(props: Record<string, any>): boolean {
  for (const key of Object.keys(props)) {
    const val = props[key];
    if (val && typeof val === 'object' && 'latitude' in val && 'longitude' in val) {
      const lat = Number(val.latitude);
      const lng = Number(val.longitude);
      if (!isNaN(lat) && !isNaN(lng)) return true;
    }
  }
  const lat = Number(props['Lat'] ?? props['lat'] ?? props['Latitude'] ?? props['latitude']);
  const lng = Number(props['Lng'] ?? props['lng'] ?? props['Longitude'] ?? props['longitude']);
  return !isNaN(lat) && !isNaN(lng);
}

const hasMapData = mapMarkers.some((r) => hasCoords(r.properties));
---

<Layout title="Dashboard" description="Explore bioregional actors, projects, and opportunities">
  <main style="max-width:var(--max-w);margin:0 auto;padding:2rem 1.5rem;">
    <header style="margin-bottom:2.5rem;">
      <h1 style="font-size:2rem;font-weight:700;margin:0 0 0.5rem 0;color:var(--fg);">Bioregioning Earth</h1>
      <p style="color:var(--muted);margin:0;font-size:1.05rem;">A living interface to the bioregional network. <strong>{totalRecords}</strong> records across <strong>{sections.length}</strong> databases.</p>
    </header>

    {hasMapData && (
      <section style="margin-bottom:3rem;">
        <EarthMap records={mapMarkers} />
      </section>
    )}

    <div style="display:grid;grid-template-columns:repeat(auto-fill, minmax(260px, 1fr));gap:1.25rem;margin-bottom:2rem;">
      {sectionsWithData.map(({ section, records }) => (
        <a
          href={`${base}${section.route}`}
          style="display:block;border-radius:var(--radius);border:1px solid var(--border);background:var(--card);padding:1.5rem;text-decoration:none;transition:transform 0.15s ease,border-color 0.15s ease;"
          onmouseenter="this.style.transform='translateY(-2px)';this.style.borderColor='var(--accent-dim)';"
          onmouseleave="this.style.transform='';this.style.borderColor='';"
        >
          <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.75rem;">
            <h2 style="margin:0;font-size:1.15rem;font-weight:600;color:var(--fg);">{section.name}</h2>
            <span style="font-size:0.85rem;color:var(--muted);background:var(--surface);padding:0.25rem 0.6rem;border-radius:999px;">{records.length}</span>
          </div>
          <p style="margin:0;font-size:0.9rem;color:var(--muted);line-height:1.45;">{section.description}</p>
        </a>
      ))}
    </div>

    {sectionsWithData.map(({ section, records }) => (
      <section style="margin-bottom:3rem;">
        <div style="display:flex;align-items:baseline;justify-content:space-between;margin-bottom:1rem;border-bottom:1px solid var(--border);padding-bottom:0.75rem;">
          <h2 style="margin:0;font-size:1.3rem;font-weight:600;color:var(--fg);">
            <a href={`${base}${section.route}`} style="color:var(--fg);">{section.name}</a>
          </h2>
          <a href={`${base}${section.route}`} style="font-size:0.85rem;color:var(--accent);">View all →</a>
        </div>
        <NetworkSection records={records.slice(0, 6)} basePath={section.route} />
      </section>
    ))}
  </main>
</Layout>
