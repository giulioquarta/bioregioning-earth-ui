---
import Layout from '../layouts/Layout.astro';
import EarthMap from '../components/EarthMap.astro';
import NetworkSection from '../components/NetworkSection.astro';
import { loadSectionConfig, fetchSectionRecords } from '../lib/notion';

const sections = loadSectionConfig();
const base = import.meta.env.BASE_URL;

const sectionsWithData = await Promise.all(
  sections.map(async (s) => {
    const records = await fetchSectionRecords(s);
    return { section: s, records };
  })
);

const totalRecords = sectionsWithData.reduce((sum, { records }) => sum + records.length, 0);

const orgsSectionData = sectionsWithData.find(({ section }) => section.id === 'bioregional-organizations');
const orgCount = orgsSectionData?.records.length ?? 0;
const orgDescription = 'Bioregional actors and initiatives currently mapped';

// For dashboard map: include section route with each record so markers link correctly
const mapMarkers = sectionsWithData.flatMap(({ section, records }) =>
  records.map(r => ({ ...r, sectionRoute: section.route }))
);

function hasCoords(props: Record<string, any>): boolean {
  for (const key of Object.keys(props)) {
    const val = props[key];
    if (val && typeof val === 'object' && !Array.isArray(val)) {
      const hasLat = val.latitude != null && val.latitude !== '';
      const hasLng = val.longitude != null && val.longitude !== '';
      if (hasLat && hasLng) {
        const lat = Number(val.latitude);
        const lng = Number(val.longitude);
        if (!isNaN(lat) && !isNaN(lng)) return true;
      }
    }
  }
  const lat = Number(
    props['Lat'] ?? props['lat'] ?? props['Latitude'] ?? props['latitude'] ??
    props['location_lat'] ?? props['location_Lat'] ?? props['Location_Lat']
  );
  const lng = Number(
    props['Lng'] ?? props['lng'] ?? props['Longitude'] ?? props['longitude'] ??
    props['location_lng'] ?? props['location_Lng'] ?? props['Location_Lng']
  );
  return !isNaN(lat) && !isNaN(lng) && (lat !== 0 || lng !== 0);
}

const hasMapData = mapMarkers.some((r) => hasCoords(r.properties));
---

<Layout title="Dashboard" description="Explore bioregional actors, projects, and opportunities">
  <main style="max-width:var(--max-w);margin:0 auto;padding:2rem 1.5rem;">
    <!-- Welcome block -->
    <header style="margin-bottom:2.5rem;">
      <h1 style="font-size:clamp(1.8rem, 4vw, 2.6rem);font-weight:500;margin:0 0 0.5rem 0;color:var(--fg);font-family:var(--serif);letter-spacing:-0.01em;">Welcome to the Bioregional Knowledge Commons</h1>
      <p style="color:var(--muted);margin:0 0 1rem 0;font-size:1.05rem;line-height:1.6;">
        This is a public knowledge base documenting organizations and practices at the frontier of bioregional work — exploring how communities around the world are learning to live and govern within the logic of place.
      </p>
      <p style="color:var(--muted);margin:0;font-size:0.95rem;line-height:1.6;">
        You can browse the map to explore where groups are practicing bioregional approaches, or click <strong>Table</strong> to see the database. For a detailed tour, visit <a href={`${base}/how-to-explore`} style="color:var(--primary);text-decoration:underline;">How to Explore the Knowledge Commons</a>.
      </p>
      <p style="color:var(--muted);margin:0.75rem 0 0 0;font-size:0.8rem;font-family:var(--mono);text-transform:uppercase;letter-spacing:0.04em;">
        <strong>{orgCount}</strong> {orgDescription}
      </p>
    </header>

    <!-- Map / Table toggle -->
    {hasMapData && (
      <section style="margin-bottom:1.5rem;">
        <div style="display:flex;align-items:center;gap:0.5rem;margin-bottom:0.75rem;">
          <span style="font-size:0.8rem;font-family:var(--mono);text-transform:uppercase;letter-spacing:0.04em;color:var(--muted);">View:</span>
          <div style="display:inline-flex;gap:0;overflow:hidden;border:1px solid var(--border);border-radius:var(--radius);background:var(--card);">
            <span style="display:inline-flex;align-items:center;gap:0.35rem;padding:0.4rem 0.7rem;font-size:0.8rem;font-family:var(--mono);text-transform:uppercase;letter-spacing:0.03em;background:var(--primary);color:var(--primary-fg);font-weight:500;cursor:default;">
              🗺️ Map
            </span>
            <a
              href={`${base}/organizations`}
              onclick="window.location.href=this.href;"
              style="display:inline-flex;align-items:center;gap:0.35rem;padding:0.4rem 0.7rem;font-size:0.8rem;font-family:var(--mono);text-transform:uppercase;letter-spacing:0.03em;color:var(--muted);text-decoration:none;transition:background 0.12s;"
              onmouseenter="this.style.background='var(--surface)';"
              onmouseleave="this.style.background='';"
            >
              🗂️ Table
            </a>
          </div>
        </div>
        <EarthMap records={mapMarkers} />
      </section>
    )}

    <!-- Database cards -->
    <div style="display:grid;grid-template-columns:repeat(auto-fill, minmax(260px, 1fr));gap:1.25rem;margin-bottom:2rem;">
      {sectionsWithData.map(({ section, records }) => (
        <a
          href={`${base}${section.route}`}
          style="display:block;border-radius:var(--radius);border:1px solid var(--border);background:var(--card);padding:1.5rem;text-decoration:none;transition:transform 0.15s ease,border-color 0.15s ease;"
          onmouseenter="this.style.transform='translateY(-2px)';this.style.borderColor='var(--paper-200)';"
          onmouseleave="this.style.transform='';this.style.borderColor='';"
        >
          <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.75rem;">
            <h2 style="margin:0;font-size:1.15rem;font-weight:600;color:var(--fg);font-family:var(--sans);">{section.name}</h2>
            <span style="font-size:0.8rem;color:var(--muted);background:var(--surface);padding:0.25rem 0.6rem;border-radius:var(--radius-pill);font-family:var(--mono);">{records.length}</span>
          </div>
          <p style="margin:0;font-size:0.9rem;color:var(--muted);line-height:1.45;">{section.description}</p>
        </a>
      ))}
    </div>

    <!-- End landing page -->
  </main>
</Layout>
