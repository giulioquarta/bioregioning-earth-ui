---
import Layout from '../layouts/Layout.astro';
import HomeEarthMap from '../components/HomeEarthMap.astro';
import OrganizationsTable from '../components/OrganizationsTable.astro';
import { loadSectionConfig, fetchSectionRecords } from '../lib/notion';

const sections = loadSectionConfig();

const sectionsWithData = await Promise.all(
  sections.map(async (s) => {
    const records = await fetchSectionRecords(s);
    return { section: s, records };
  })
);

const orgsData = sectionsWithData.find(({ section }) => section.id === 'bioregional-organizations');
const orgRecords = orgsData?.records ?? [];
const orgCount = orgRecords.length;
const orgDescription = 'Bioregional actors and initiatives currently mapped';

const mapMarkers = sectionsWithData.flatMap(({ section, records }) =>
  records.map(r => ({ ...r, sectionRoute: section.route }))
);
---

<Layout title="Dashboard" description="Explore bioregional actors, projects, and opportunities" hideFooter={true}>
  <main style="padding:0;max-width:none;height:calc(100vh - 56px);position:relative;">
    <!-- Floating view toggle -->
    <div
      id="view-toggle"
      style="position:absolute;top:1rem;left:1rem;z-index:30;display:inline-flex;gap:0;overflow:hidden;border:1px solid var(--border);border-radius:var(--radius);background:var(--card);box-shadow:0 4px 16px rgba(42,24,16,0.15);"
    >
      <button
        data-view="map"
        style="padding:0.55rem 1rem;font-size:0.85rem;font-family:var(--mono);text-transform:uppercase;letter-spacing:0.03em;background:var(--primary);color:var(--primary-fg);border:none;cursor:pointer;font-weight:500;"
      >
        🗺️ Map
      </button>
      <button
        data-view="table"
        style="padding:0.55rem 1rem;font-size:0.85rem;font-family:var(--mono);text-transform:uppercase;letter-spacing:0.03em;background:var(--card);color:var(--muted);border:none;cursor:pointer;"
      >
        🗂️ Table
      </button>
    </div>

    <!-- Map view -->
    <div id="map-view" style="width:100%;height:100%;">
      <HomeEarthMap records={mapMarkers} orgCount={orgCount} orgDescription={orgDescription} />
    </div>

    <!-- Table view -->
    <div id="table-view" style="display:none;width:100%;height:100%;overflow:auto;padding:4rem 1.5rem 1.5rem 1.5rem;box-sizing:border-box;">
      <div style="max-width:var(--max-w);margin:0 auto;">
        <header style="margin-bottom:1.5rem;">
          <h1 style="font-size:clamp(1.6rem, 3vw, 2.2rem);font-weight:500;margin:0 0 0.5rem 0;color:var(--fg);font-family:var(--serif);letter-spacing:-0.01em;">Organizations</h1>
          <p style="color:var(--muted);margin:0;font-size:0.9rem;">
            <strong>{orgCount}</strong> {orgDescription}
          </p>
        </header>
        <OrganizationsTable records={orgRecords} basePath="/organizations" />
      </div>
    </div>
  </main>

  <script>
    function setView(view) {
      const mapView = document.getElementById('map-view');
      const tableView = document.getElementById('table-view');
      const buttons = document.querySelectorAll('#view-toggle button');

      if (!mapView || !tableView) return;

      if (view === 'table') {
        mapView.style.display = 'none';
        tableView.style.display = 'block';
      } else {
        mapView.style.display = 'block';
        tableView.style.display = 'none';
      }

      buttons.forEach((btn) => {
        const isActive = btn.dataset.view === view;
        btn.style.background = isActive ? 'var(--primary)' : 'var(--card)';
        btn.style.color = isActive ? 'var(--primary-fg)' : 'var(--muted)';
        btn.style.fontWeight = isActive ? '500' : '400';
      });
    }

    function readHash() {
      return window.location.hash === '#table' ? 'table' : 'map';
    }

    document.querySelectorAll('#view-toggle button').forEach((btn) => {
      btn.addEventListener('click', () => {
        const view = btn.dataset.view;
        window.location.hash = view === 'table' ? 'table' : '';
        setView(view);
      });
    });

    window.addEventListener('hashchange', () => setView(readHash()));

    setView(readHash());
  </script>
</Layout>
