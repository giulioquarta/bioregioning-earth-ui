---
import Layout from '../layouts/Layout.astro';
import { loadSectionConfig, fetchDatabaseRecords } from '../lib/notion';

const base = import.meta.env.BASE_URL;
const sections = loadSectionConfig();
const orgsSection = sections.find((s) => s.id === 'bioregional-organizations');

let records: any[] = [];
if (orgsSection && orgsSection.database_id) {
  records = await fetchDatabaseRecords(orgsSection.database_id);
}

// Helper: extract lat/lng from a record, supporting both Notion location properties and raw Lat/Lng numbers
function getCoords(r: any): { lat: number; lng: number; address?: string } | null {
  const props = r.properties ?? {};

  // 1. Try Notion "location" type property (e.g. "Place", "Location")
  for (const key of Object.keys(props)) {
    const val = props[key];
    if (val && typeof val === 'object' && !Array.isArray(val)) {
      const hasLat = val.latitude != null && val.latitude !== '';
      const hasLng = val.longitude != null && val.longitude !== '';
      if (hasLat && hasLng) {
        const lat = Number(val.latitude);
        const lng = Number(val.longitude);
        if (!isNaN(lat) && !isNaN(lng)) {
          return { lat, lng, address: val.address };
        }
      }
    }
  }

  // 2. Fall back to raw Lat/Lng number properties
  const lat = Number(props['Lat'] ?? props['lat'] ?? props['Latitude'] ?? props['latitude']);
  const lng = Number(props['Lng'] ?? props['lng'] ?? props['Longitude'] ?? props['longitude']);
  if (!isNaN(lat) && !isNaN(lng)) {
    return { lat, lng };
  }

  return null;
}

// Build-time debug: scan ALL records and print a frequency table of every property name
if (records.length > 0) {
  const freq: Record<string, { count: number; types: Set<string>; sample: any }> = {};
  let totalWithCoords = 0;

  for (const r of records) {
    for (const [k, v] of Object.entries(r.properties)) {
      if (!freq[k]) freq[k] = { count: 0, types: new Set(), sample: v };
      freq[k].count++;
      freq[k].types.add(v === null ? 'null' : Array.isArray(v) ? 'array' : typeof v);

      const isObj = v !== null && typeof v === 'object' && !Array.isArray(v);
      if (isObj && 'latitude' in v && 'longitude' in v) {
        const lat = Number(v.latitude);
        const lng = Number(v.longitude);
        if (!isNaN(lat) && !isNaN(lng)) {
          totalWithCoords++;
          if (totalWithCoords === 1) {
            console.log(`[map.astro debug] FIRST COORDS FOUND in property "${k}": lat=${lat}, lng=${lng}, address=${v.address}`);
          }
        }
      }
    }
  }

  const table = Object.entries(freq)
    .map(([k, v]) => ({
      property: k,
      presentIn: `${v.count}/${records.length}`,
      types: Array.from(v.types).join('|'),
      sample: JSON.stringify(v.sample).slice(0, 120),
    }))
    .sort((a, b) => b.presentIn.localeCompare(a.presentIn));

  console.log('[map.astro debug] === PROPERTY FREQUENCY TABLE ===');
  for (const row of table) {
    console.log(`  ${row.property.padEnd(22)} | ${row.presentIn.padStart(7)} | ${row.types.padStart(12)} | ${row.sample}`);
  }
  console.log(`[map.astro debug] Total records: ${records.length}`);
  console.log(`[map.astro debug] Records with valid coords: ${totalWithCoords}`);
}

const markers = records
  .map((r) => {
    const coords = getCoords(r);
    if (!coords) return null;
    const name = String(r.properties['Name'] ?? r.properties['Title'] ?? 'Untitled');
    const slug = r.id.replace(/-/g, '');
    const href = `${base}/organizations/${slug}`;
    const type = String(r.properties['Type'] ?? r.properties['type'] ?? r.properties['Tags'] ?? r.properties['tags'] ?? '');
    const scope = String(r.properties['Scope'] ?? r.properties['scope'] ?? r.properties['Comarca'] ?? r.properties['comarca'] ?? coords.address ?? '');
    return { id: r.id, lat: coords.lat, lng: coords.lng, name, href, type, scope };
  })
  .filter(Boolean) as Array<{ id: string; lat: number; lng: number; name: string; href: string; type: string; scope: string }>;

const hasMapData = markers.length > 0;
---

<Layout title="Map" description="Interactive map of bioregional organizations">
  <main style="position:relative;height:calc(100vh - 56px);overflow:hidden;background:var(--ivory);">
    {hasMapData ? (
      <>
        <!-- Full-screen map -->
        <div id="map-fullscreen" style="position:absolute;inset:0;" data-markers={JSON.stringify(markers)}></div>

        <!-- Floating sidebar -->
        <aside
          id="map-sidebar"
          style="position:absolute;top:1rem;left:1rem;width:300px;max-height:calc(100% - 2rem);overflow-y:auto;background:rgba(251,249,243,0.94);backdrop-filter:blur(12px);border:1px solid var(--border);border-radius:var(--radius);padding:1rem;z-index:10;box-shadow:0 4px 24px rgba(29,26,22,0.08);"
        >
          <h2 style="margin:0 0 0.75rem 0;font-size:1.1rem;font-weight:600;color:var(--fg);font-family:var(--serif);">🌍 Organizations ({markers.length})</h2>
          <div style="display:flex;flex-direction:column;gap:0.5rem;">
            {markers.map((m) => (
              <a
                href={m.href}
                style="display:block;padding:0.55rem 0.7rem;border-radius:8px;background:var(--card);border:1px solid var(--border);text-decoration:none;transition:background 0.12s;"
                onmouseenter="this.style.background='var(--surface)';"
                onmouseleave="this.style.background='var(--card)';"
              >
                <div style="font-size:0.88rem;font-weight:500;color:var(--fg);margin-bottom:0.15rem;font-family:var(--serif);">{m.name}</div>
                <div style="font-size:0.72rem;color:var(--muted);display:flex;gap:0.4rem;flex-wrap:wrap;font-family:var(--mono);text-transform:uppercase;letter-spacing:0.03em;">
                  {m.type && <span>{m.type}</span>}
                  {m.scope && <span>· {m.scope}</span>}
                </div>
              </a>
            ))}
          </div>
        </aside>

        <!-- Mobile sidebar toggle -->
        <button
          id="sidebar-toggle"
          style="display:none;position:absolute;top:1rem;left:1rem;z-index:20;background:var(--card);border:1px solid var(--border);border-radius:999px;padding:0.5rem 0.75rem;font-family:var(--mono);font-size:0.75rem;text-transform:uppercase;letter-spacing:0.04em;cursor:pointer;box-shadow:0 2px 8px rgba(29,26,22,0.08);"
        >
          ☰ List
        </button>
      </>
    ) : (
      <div style="display:flex;align-items:center;justify-content:center;height:100%;color:var(--muted);padding:2rem;text-align:center;">
        <div>
          <div style="font-size:1.5rem;margin-bottom:0.75rem;">🗺️</div>
          <p style="margin:0 0 0.5rem 0;font-family:var(--serif);font-weight:500;">No geolocated organizations found.</p>
          <p style="margin:0;font-size:0.9rem;opacity:0.7;font-family:var(--mono);">Check that your Notion database has a <strong>Place</strong> (location) property or <strong>Lat/Lng</strong> number properties.</p>
          {records.length > 0 && (
            <p style="margin-top:1rem;font-size:0.8rem;font-family:var(--mono);opacity:0.6;">{records.length} records loaded, none with valid coordinates.</p>
          )}
        </div>
      </div>
    )}
  </main>

  <script>
    import maplibregl from 'maplibre-gl';
    import 'maplibre-gl/dist/maplibre-gl.css';

    function initMap() {
      const container = document.getElementById('map-fullscreen');
      if (!container) return;

      const markers = JSON.parse(container.dataset.markers || '[]');
      if (markers.length === 0) return;

      const avgLat = markers.reduce((s, m) => s + m.lat, 0) / markers.length;
      const avgLng = markers.reduce((s, m) => s + m.lng, 0) / markers.length;

      const map = new maplibregl.Map({
        container,
        style: {
          version: 8,
          sources: {
            osm: {
              type: 'raster',
              tiles: ['https://tile.openstreetmap.org/{z}/{x}/{y}.png'],
              tileSize: 256,
              attribution: '&copy; OpenStreetMap contributors',
            },
          },
          layers: [{ id: 'osm', type: 'raster', source: 'osm' }],
        },
        center: [avgLng || 0, avgLat || 20],
        zoom: markers.length === 1 ? 5 : 2,
      });

      map.addControl(new maplibregl.NavigationControl(), 'top-right');
      map.addControl(new maplibregl.FullscreenControl(), 'top-right');
      map.addControl(new maplibregl.ScaleControl(), 'bottom-left');

      const bounds = new maplibregl.LngLatBounds();

      for (const m of markers) {
        const el = document.createElement('div');
        el.style.cssText = 'width:18px;height:18px;border-radius:50%;background:#CDFF58;border:2.5px solid var(--ink);box-shadow:0 2px 8px rgba(0,0,0,0.25);cursor:pointer;transition:transform 0.12s;';
        el.onmouseenter = () => { el.style.transform = 'scale(1.4)'; };
        el.onmouseleave = () => { el.style.transform = ''; };

        const popupHtml = `
          <div style="font-family:system-ui,sans-serif;min-width:180px;">
            <a href="${m.href}" style="font-weight:700;font-size:0.95rem;color:var(--accent);text-decoration:none;display:block;margin-bottom:0.3rem;">${m.name}</a>
            ${m.type ? `<div style="font-size:0.8rem;color:var(--muted);margin-bottom:0.2rem;">${m.type}</div>` : ''}
            ${m.scope ? `<div style="font-size:0.75rem;color:var(--muted);">${m.scope}</div>` : ''}
          </div>
        `;

        const popup = new maplibregl.Popup({ offset: 14, closeButton: false }).setHTML(popupHtml);

        new maplibregl.Marker({ element: el })
          .setLngLat([m.lng, m.lat])
          .setPopup(popup)
          .addTo(map);

        bounds.extend([m.lng, m.lat]);

        // Click marker to navigate to detail page
        el.addEventListener('click', () => {
          window.location.href = m.href;
        });
      }

      if (markers.length > 1) {
        map.fitBounds(bounds, { padding: 80, maxZoom: 10 });
      }

      // Mobile sidebar toggle
      const sidebar = document.getElementById('map-sidebar');
      const toggle = document.getElementById('sidebar-toggle');
      if (sidebar && toggle) {
        const mq = window.matchMedia('(max-width: 640px)');
        function apply() {
          if (mq.matches) {
            toggle.style.display = 'block';
            sidebar.style.display = 'none';
            sidebar.style.top = '3.5rem';
            sidebar.style.left = '0.5rem';
            sidebar.style.right = '0.5rem';
            sidebar.style.width = 'auto';
          } else {
            toggle.style.display = 'none';
            sidebar.style.display = 'block';
            sidebar.style.top = '1rem';
            sidebar.style.left = '1rem';
            sidebar.style.right = '';
            sidebar.style.width = '300px';
          }
        }
        apply();
        mq.addEventListener('change', apply);
        toggle.addEventListener('click', () => {
          sidebar.style.display = sidebar.style.display === 'none' ? 'block' : 'none';
        });
      }
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initMap);
    } else {
      initMap();
    }
  </script>
</Layout>
