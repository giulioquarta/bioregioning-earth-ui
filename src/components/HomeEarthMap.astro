---
import type { NormalizedRecord } from '../lib/notion';
import OrgDetail from './OrgDetail.astro';

export interface Props {
  records?: Array<{
    id: string;
    url?: string;
    properties: Record<string, any>;
    sectionRoute?: string;
  }>;
  basePath?: string;
  orgCount?: number;
  orgDescription?: string;
  lookups?: {
    tags?: Map<string, NormalizedRecord>;
    activities?: Map<string, NormalizedRecord>;
    sources?: Map<string, NormalizedRecord>;
    affiliations?: Map<string, NormalizedRecord>;
  };
}
const { records = [], basePath = '/', orgCount = 0, orgDescription = '', lookups = {} } = Astro.props;
const base = import.meta.env.BASE_URL;

function getCoords(props: Record<string, any>): { lat: number; lng: number } | null {
  for (const key of Object.keys(props)) {
    const val = props[key];
    if (val && typeof val === 'object' && !Array.isArray(val)) {
      const lat = val.latitude != null ? Number(val.latitude) : val.lat != null ? Number(val.lat) : null;
      const lng = val.longitude != null ? Number(val.longitude) : val.lon != null ? Number(val.lon) : null;
      if (lat !== null && lng !== null && !isNaN(lat) && !isNaN(lng)) {
        return { lat, lng };
      }
    }
  }
  const lat = Number(
    props['Lat'] ?? props['lat'] ?? props['Latitude'] ?? props['latitude'] ??
    props['location_lat'] ?? props['location_Lat'] ?? props['Location_Lat']
  );
  const lng = Number(
    props['Lng'] ?? props['lng'] ?? props['Longitude'] ?? props['longitude'] ??
    props['location_lng'] ?? props['location_Lng'] ?? props['Location_Lng']
  );
  if (!isNaN(lat) && !isNaN(lng) && (lat !== 0 || lng !== 0)) return { lat, lng };
  return null;
}

const markers = records
  .map((r) => {
    const coords = getCoords(r.properties);
    if (!coords) return null;
    const name = String(r.properties['Name'] ?? r.properties['Title'] ?? 'Untitled');
    const slug = r.id.replace(/-/g, '');
    const pathPrefix = r.sectionRoute ? r.sectionRoute.replace(/\/$/, '') : basePath.replace(/\/$/, '');
    const href = `${base}${pathPrefix}/${slug}`;
    const caseStudy = r.properties['Case Study'] ?? null;
    return {
      id: r.id,
      lat: coords.lat,
      lng: coords.lng,
      name,
      href,
      caseStudy,
    };
  })
  .filter(Boolean) as Array<{ id: string; lat: number; lng: number; name: string; href: string; caseStudy: string | null }>;

const hasLookups = Object.keys(lookups).length > 0;
---

<div style="position:relative;width:100%;height:100%;overflow:hidden;">
  <div id="home-map" style="width:100%;height:100%;" data-markers={JSON.stringify(markers)} data-base={base}></div>

  <!-- Side panel -->
  <div
    id="home-panel"
    style="position:absolute;top:0.5rem;right:0.5rem;bottom:0.5rem;width:400px;max-width:40%;background:rgba(255,255,255,0.98);backdrop-filter:blur(12px);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;box-shadow:0 8px 32px rgba(42,24,16,0.12);font-family:var(--sans);z-index:20;display:flex;flex-direction:column;"
  >
    <!-- Header -->
    <div style="display:flex;align-items:center;justify-content:space-between;padding:0.875rem 1.25rem;border-bottom:1px solid var(--border);flex-shrink:0;">
      <span id="panel-welcome-label" style="font-size:0.7rem;font-family:var(--mono);text-transform:uppercase;letter-spacing:0.05em;color:var(--muted);">Welcome</span>
      <button id="panel-back-btn" style="display:none;background:none;border:none;color:var(--muted);font-size:0.8rem;cursor:pointer;font-family:var(--mono);text-transform:uppercase;letter-spacing:0.03em;padding:0;" aria-label="Back to welcome">← Back</button>
    </div>

    <!-- Scrollable content -->
    <div id="panel-content" style="padding:1.25rem;overflow-y:auto;flex:1;">

      <!-- Welcome view -->
      <div id="panel-welcome">
        <h1 style="font-size:clamp(1.5rem, 2.5vw, 2rem);font-weight:500;margin:0 0 0.6rem 0;color:var(--fg);font-family:var(--serif);letter-spacing:-0.01em;line-height:1.2;">Welcome to the Bioregional Knowledge Commons</h1>
        <p style="color:var(--muted);margin:0 0 0.75rem 0;font-size:0.9rem;line-height:1.55;">This is a public knowledge base documenting organizations and practices at the frontier of bioregional work — exploring how communities around the world are learning to live and govern within the logic of place.</p>
        <p style="color:var(--muted);margin:0 0 1rem 0;font-size:0.75rem;font-family:var(--mono);text-transform:uppercase;letter-spacing:0.04em;">
          <strong style="color:var(--fg);">{orgCount}</strong> {orgDescription}
        </p>

        <!-- Map / Table toggle -->
        <div style="display:inline-flex;gap:0;overflow:hidden;border:1px solid var(--border);border-radius:var(--radius);background:var(--card);margin-bottom:1rem;">
          <span style="display:inline-flex;align-items:center;gap:0.35rem;padding:0.4rem 0.7rem;font-size:0.75rem;font-family:var(--mono);text-transform:uppercase;letter-spacing:0.03em;background:var(--primary);color:var(--primary-fg);font-weight:500;cursor:default;">🗺️ Map</span>
          <a href="#table" style="display:inline-flex;align-items:center;gap:0.35rem;padding:0.4rem 0.7rem;font-size:0.75rem;font-family:var(--mono);text-transform:uppercase;letter-spacing:0.03em;color:var(--muted);text-decoration:none;transition:background 0.12s;" onmouseenter="this.style.background='var(--surface)'" onmouseleave="this.style.background=''">🗂️ Table</a>
        </div>
      </div>

      <!-- Detail view -->
      <div id="panel-detail" style="display:none;"></div>

    </div>
  </div>
</div>

{hasLookups && (
  <div style="display:none;">
    {records.map((r) => (
      <div id={`home-detail-${r.id}`} class="home-detail-template">
        <OrgDetail record={r} lookups={lookups} mode="panel" />
      </div>
    ))}
  </div>
)}

<script>
  import maplibregl from 'maplibre-gl';
  import 'maplibre-gl/dist/maplibre-gl.css';

  function initMap() {
    const container = document.getElementById('home-map');
    if (!container) return;

    const hasLookups = document.querySelector('.home-detail-template') !== null;

    const markers = JSON.parse(container.dataset.markers || '[]');
    const base = container.dataset.base || '';

    if (markers.length === 0) {
      container.innerHTML = '<div style="display:flex;align-items:center;justify-content:center;height:100%;color:var(--muted);font-size:0.9rem;font-family:var(--mono);">No geolocated records to display.</div>';
      return;
    }

    const avgLat = markers.reduce((s, m) => s + m.lat, 0) / markers.length;
    const avgLng = markers.reduce((s, m) => s + m.lng, 0) / markers.length;

    const map = new maplibregl.Map({
      container,
      style: {
        version: 8,
        sources: {
          osm: {
            type: 'raster',
            tiles: ['https://tile.openstreetmap.org/{z}/{x}/{y}.png'],
            tileSize: 256,
            attribution: '&copy; OpenStreetMap contributors',
          },
        },
        layers: [{ id: 'osm', type: 'raster', source: 'osm' }],
      },
      center: [avgLng || 0, avgLat || 20],
      zoom: markers.length === 1 ? 4 : 2,
    });

    map.addControl(new maplibregl.NavigationControl(), 'bottom-left');
    map.addControl(new maplibregl.FullscreenControl(), 'bottom-left');
    window.addEventListener('view-changed', (e) => {
      if (e.detail?.view === 'map') {
        setTimeout(() => map.resize(), 0);
      }
    });

    const bounds = new maplibregl.LngLatBounds();

    const welcomeDiv = document.getElementById('panel-welcome');
    const detailDiv = document.getElementById('panel-detail');
    const welcomeLabel = document.getElementById('panel-welcome-label');
    const backBtn = document.getElementById('panel-back-btn');
    const contentDiv = document.getElementById('panel-content');
    const panel = document.getElementById('home-panel');

    function showWelcome() {
      detailDiv.style.display = 'none';
      welcomeDiv.style.display = 'block';
      welcomeLabel.style.display = 'inline';
      backBtn.style.display = 'none';
      if (contentDiv) contentDiv.scrollTop = 0;
    }

    function showDetail(m) {
      welcomeDiv.style.display = 'none';
      welcomeLabel.style.display = 'none';
      backBtn.style.display = 'inline-block';

      if (hasLookups) {
        const template = document.getElementById(`home-detail-${m.id}`);
        if (template) {
          detailDiv.innerHTML = template.innerHTML;
        } else {
          detailDiv.innerHTML = '<p style="color:var(--muted);">Detail not available.</p>';
        }
      } else {
        detailDiv.innerHTML = `
          <h2 style="font-size:clamp(1.3rem, 2.5vw, 1.6rem);font-weight:500;margin:0 0 0.6rem 0;color:var(--fg);line-height:1.2;font-family:var(--serif);letter-spacing:-0.01em;">${m.name}</h2>
          <div style="display:flex;gap:0.6rem;flex-wrap:wrap;">
            <a href="${m.href}" target="_blank" rel="noopener noreferrer" style="display:inline-block;padding:0.5rem 0.9rem;border-radius:var(--radius);background:var(--primary);color:var(--primary-fg);font-size:0.75rem;text-decoration:none;font-family:var(--mono);text-transform:uppercase;letter-spacing:0.03em;">View full page →</a>
          </div>
        `;
      }
      detailDiv.style.display = 'block';
      if (contentDiv) contentDiv.scrollTop = 0;
    }

    backBtn?.addEventListener('click', showWelcome);
    panel?.addEventListener('click', (e) => e.stopPropagation());

    function placeMarkers() {
      for (const m of markers) {
        const pinColor = m.caseStudy === 'Y' ? '#F0A030' : '#B0A090';
        const marker = new maplibregl.Marker({ color: pinColor, scale: 0.8 })
          .setLngLat([m.lng, m.lat])
          .addTo(map);

        marker.getElement().addEventListener('click', (e) => {
          e.stopPropagation();
          showDetail(m);
        });

        bounds.extend([m.lng, m.lat]);
      }

      if (markers.length > 1) {
        map.fitBounds(bounds, { padding: 40, maxZoom: 8 });
      }

      map.on('click', showWelcome);
    }

    if (map.loaded()) {
      placeMarkers();
    } else {
      map.on('load', placeMarkers);
    }

    // Ensure the map renders at the correct size after the container is laid out
    requestAnimationFrame(() => map.resize());
  }

  if (document.readyState === 'complete') {
    initMap();
  } else {
    window.addEventListener('load', initMap);
  }
</script>
