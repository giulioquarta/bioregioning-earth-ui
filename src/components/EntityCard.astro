---
export interface Props {
  id: string;
  title: string;
  subtitle?: string;
  tags?: string[];
  url?: string | null;
  basePath?: string;
}
const { id, title, subtitle, tags = [], url, basePath = '/' } = Astro.props;
const slug = id.replace(/-/g, '');
const base = import.meta.env.BASE_URL;
const cleanBasePath = basePath.endsWith('/') ? basePath.slice(0, -1) : basePath;
const href = `${base}${cleanBasePath}/${slug}`;
---

<a
  href={href}
  class="entity-card"
  style="display:block;border-radius:var(--radius);border:1px solid var(--border);background:var(--card);padding:1.25rem;text-decoration:none;transition:transform 0.15s ease,border-color 0.15s ease,box-shadow 0.15s ease;"
  onmouseenter="this.style.transform='translateY(-2px)';this.style.borderColor='rgba(29,26,22,0.22)';this.style.boxShadow='0 4px 20px rgba(29,26,22,0.06)';"
  onmouseleave="this.style.transform='';this.style.borderColor='';this.style.boxShadow='';"
>
  <h3 style="margin:0 0 0.4rem 0;font-size:1.05rem;font-weight:600;color:var(--fg);line-height:1.35;font-family:var(--serif);">{title}</h3>
  {subtitle && <p style="margin:0 0 0.75rem 0;font-size:0.875rem;color:var(--muted);line-height:1.45;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">{subtitle}</p>}
  <div style="display:flex;flex-wrap:wrap;gap:0.4rem;margin-bottom:0.5rem;">
    {tags.slice(0, 4).map((t) => (
      <span style="font-size:0.75rem;padding:0.2rem 0.6rem;border-radius:999px;background:var(--surface);color:var(--accent);border:1px solid var(--border);white-space:nowrap;font-family:var(--mono);text-transform:uppercase;letter-spacing:0.02em;">
        {t}
      </span>
    ))}
    {tags.length > 4 && (
      <span style="font-size:0.75rem;padding:0.2rem 0.6rem;border-radius:999px;background:var(--surface);color:var(--muted);border:1px solid var(--border);font-family:var(--mono);">+{tags.length - 4}</span>
    )}
  </div>
  {url && (
    <p style="margin:0;font-size:0.78rem;color:var(--accent);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;font-family:var(--mono);">{url}</p>
  )}
</a>
