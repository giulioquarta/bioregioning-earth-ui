---
import type { NormalizedRecord } from '../lib/notion';

export interface Props {
  records: NormalizedRecord[];
  basePath?: string;
}
const { records, basePath = '/' } = Astro.props;
const base = import.meta.env.BASE_URL;

function getTitle(r: NormalizedRecord): string {
  return String(r.properties['Name'] ?? r.properties['Title'] ?? r.properties['name'] ?? r.properties['title'] ?? 'Untitled');
}

function getType(r: NormalizedRecord): string {
  return String(r.properties['Type'] ?? r.properties['type'] ?? r.properties['Tags']?.[0] ?? r.properties['tags']?.[0] ?? '');
}

function getLocation(r: NormalizedRecord): string {
  return String(
    r.properties['Scope'] ?? r.properties['scope'] ??
    r.properties['Comarca'] ?? r.properties['comarca'] ??
    r.properties['Place']?.address ??
    ''
  );
}
---

<div style="overflow-x:auto;border:1px solid var(--border);border-radius:var(--radius);background:var(--card);">
  <table style="width:100%;border-collapse:collapse;font-size:0.9rem;">
    <thead>
      <tr style="border-bottom:1px solid var(--border);background:var(--surface);">
        <th style="text-align:left;padding:0.75rem 1rem;font-family:var(--mono);font-size:0.7rem;text-transform:uppercase;letter-spacing:0.05em;color:var(--muted);font-weight:500;">Name</th>
        <th style="text-align:left;padding:0.75rem 1rem;font-family:var(--mono);font-size:0.7rem;text-transform:uppercase;letter-spacing:0.05em;color:var(--muted);font-weight:500;">Type</th>
        <th style="text-align:left;padding:0.75rem 1rem;font-family:var(--mono);font-size:0.7rem;text-transform:uppercase;letter-spacing:0.05em;color:var(--muted);font-weight:500;">Location</th>
        <th style="text-align:left;padding:0.75rem 1rem;font-family:var(--mono);font-size:0.7rem;text-transform:uppercase;letter-spacing:0.05em;color:var(--muted);font-weight:500;">Link</th>
      </tr>
    </thead>
    <tbody>
      {records.map((r) => {
        const slug = r.id.replace(/-/g, '');
        const href = `${base}${basePath.replace(/\/$/, '')}/${slug}`;
        return (
          <tr style="border-bottom:1px solid var(--border);" onmouseenter="this.style.background='var(--surface)'" onmouseleave="this.style.background=''">
            <td style="padding:0.6rem 1rem;color:var(--fg);font-weight:500;">
              <a href={href} style="color:var(--fg);text-decoration:none;">{getTitle(r)}</a>
            </td>
            <td style="padding:0.6rem 1rem;color:var(--muted);font-size:0.85rem;">{getType(r)}</td>
            <td style="padding:0.6rem 1rem;color:var(--muted);font-size:0.85rem;">{getLocation(r)}</td>
            <td style="padding:0.6rem 1rem;">
              <a href={href} style="color:var(--primary);font-family:var(--mono);font-size:0.75rem;text-transform:uppercase;letter-spacing:0.03em;">View →</a>
            </td>
          </tr>
        );
      })}
    </tbody>
  </table>
</div>
