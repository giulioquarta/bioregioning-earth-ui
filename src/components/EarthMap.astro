---
export interface Props {
  records?: Array<{
    id: string;
    properties: Record<string, any>;
  }>;
}
const { records = [] } = Astro.props;

const markers = records
  .filter((r) => {
    const lat = Number(r.properties['Lat'] ?? r.properties['lat'] ?? r.properties['Latitude']);
    const lng = Number(r.properties['Lng'] ?? r.properties['lng'] ?? r.properties['Longitude']);
    return !isNaN(lat) && !isNaN(lng);
  })
  .map((r) => {
    const lat = Number(r.properties['Lat'] ?? r.properties['lat'] ?? r.properties['Latitude']);
    const lng = Number(r.properties['Lng'] ?? r.properties['lng'] ?? r.properties['Longitude']);
    const name = String(r.properties['Name'] ?? r.properties['Title'] ?? 'Untitled');
    return { id: r.id, lat, lng, name };
  });
---

<div id="earth-map" class="w-full h-[600px] rounded-lg overflow-hidden border border-[var(--border)]" data-markers={JSON.stringify(markers)}></div>

<script>
  import maplibregl from 'maplibre-gl';
  import 'maplibre-gl/dist/maplibre-gl.css';

  function initMap() {
    const container = document.getElementById('earth-map');
    if (!container) return;

    const markers = JSON.parse(container.dataset.markers || '[]');

    const map = new maplibregl.Map({
      container,
      style: {
        version: 8,
        sources: {
          osm: {
            type: 'raster',
            tiles: ['https://tile.openstreetmap.org/{z}/{x}/{y}.png'],
            tileSize: 256,
            attribution: '&copy; OpenStreetMap contributors',
          },
        },
        layers: [{ id: 'osm', type: 'raster', source: 'osm' }],
      },
      center: [0, 20],
      zoom: 1.5,
    });

    map.addControl(new maplibregl.NavigationControl(), 'top-right');

    for (const m of markers) {
      const el = document.createElement('div');
      el.className = 'w-3 h-3 rounded-full bg-[var(--accent)] border border-white shadow cursor-pointer';
      const popup = new maplibregl.Popup({ offset: 8 }).setHTML(
        `<a href="./${m.id.replace(/-/g, '')}" class="font-semibold">${m.name}</a>`
      );
      new maplibregl.Marker({ element: el })
        .setLngLat([m.lng, m.lat])
        .setPopup(popup)
        .addTo(map);
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initMap);
  } else {
    initMap();
  }
</script>
