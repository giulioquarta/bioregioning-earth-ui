---
export interface Props {
  records?: Array<{
    id: string;
    url?: string;
    properties: Record<string, any>;
    sectionRoute?: string;
  }>;
  basePath?: string;
}
const { records = [], basePath = '/' } = Astro.props;
const base = import.meta.env.BASE_URL;

function getCoords(props: Record<string, any>): { lat: number; lng: number } | null {
  // 1. Try Notion "location" / "place" type property (uses lat/lon)
  for (const key of Object.keys(props)) {
    const val = props[key];
    if (val && typeof val === 'object' && !Array.isArray(val)) {
      const lat = val.latitude != null ? Number(val.latitude) : val.lat != null ? Number(val.lat) : null;
      const lng = val.longitude != null ? Number(val.longitude) : val.lon != null ? Number(val.lon) : null;
      if (lat !== null && lng !== null && !isNaN(lat) && !isNaN(lng)) {
        return { lat, lng };
      }
    }
  }
  // 2. Fall back to raw number properties
  const lat = Number(
    props['Lat'] ?? props['lat'] ?? props['Latitude'] ?? props['latitude'] ??
    props['location_lat'] ?? props['location_Lat'] ?? props['Location_Lat']
  );
  const lng = Number(
    props['Lng'] ?? props['lng'] ?? props['Longitude'] ?? props['longitude'] ??
    props['location_lng'] ?? props['location_Lng'] ?? props['Location_Lng']
  );
  if (!isNaN(lat) && !isNaN(lng) && (lat !== 0 || lng !== 0)) return { lat, lng };
  return null;
}

function formatValue(value: any): string {
  if (value === null || value === undefined) return '';
  if (Array.isArray(value)) return value.join(', ');
  if (typeof value === 'object') {
    if ('address' in value && value.address) return String(value.address);
    if ('name' in value && value.name) return String(value.name);
    if ('latitude' in value && 'longitude' in value) {
      return `${value.latitude}, ${value.longitude}`;
    }
    try {
      return JSON.stringify(value);
    } catch {
      return '[Object]';
    }
  }
  return String(value);
}

const markers = records
  .map((r) => {
    const coords = getCoords(r.properties);
    if (!coords) return null;
    const name = String(r.properties['Name'] ?? r.properties['Title'] ?? 'Untitled');
    const slug = r.id.replace(/-/g, '');
    const pathPrefix = r.sectionRoute ? r.sectionRoute.replace(/\/$/, '') : basePath.replace(/\/$/, '');
    const href = `${base}${pathPrefix}/${slug}`;
    const caseStudy = r.properties['Case Study'] ?? null;
    return {
      id: r.id,
      lat: coords.lat,
      lng: coords.lng,
      name,
      href,
      url: r.url ?? null,
      properties: r.properties,
      caseStudy,
    };
  })
  .filter(Boolean) as Array<{
    id: string; lat: number; lng: number; name: string; href: string; url: string | null; properties: Record<string, any>; caseStudy: string | null;
  }>;
---

<div style="position:relative;width:100%;height:480px;border-radius:var(--radius);overflow:hidden;border:1px solid var(--border);">
  <div id="earth-map" style="width:100%;height:100%;" data-markers={JSON.stringify(markers)}></div>

  <!-- Side panel -->
  <div
    id="map-panel"
    style="display:none;position:absolute;top:0.5rem;right:0.5rem;bottom:0.5rem;width:380px;max-width:calc(100% - 1rem);background:rgba(255,255,255,0.98);backdrop-filter:blur(12px);border:1px solid var(--border);border-radius:var(--radius);padding:0;z-index:20;overflow:hidden;box-shadow:0 8px 32px rgba(42,24,16,0.12);font-family:var(--sans);"
  >
    <div style="display:flex;align-items:center;justify-content:space-between;padding:1rem 1.25rem;border-bottom:1px solid var(--border);">
      <span style="font-size:0.7rem;font-family:var(--mono);text-transform:uppercase;letter-spacing:0.05em;color:var(--muted);">Detail</span>
      <button id="map-panel-close" style="background:none;border:none;color:var(--muted);font-size:1.1rem;cursor:pointer;line-height:1;padding:0;" aria-label="Close panel">✕</button>
    </div>
    <div id="map-panel-content" style="padding:1.25rem;overflow-y:auto;height:calc(100% - 52px);"></div>
  </div>
</div>

<script>
  import maplibregl from 'maplibre-gl';
  import 'maplibre-gl/dist/maplibre-gl.css';

  function renderProperties(props) {
    const entries = Object.entries(props).filter(([key, value]) => {
      if (value === null || value === undefined || value === '' || (Array.isArray(value) && value.length === 0)) return false;
      return true;
    });
    if (entries.length === 0) return '';

    function fmt(v) {
      if (v === null || v === undefined) return '';
      if (Array.isArray(v)) return v.join(', ');
      if (typeof v === 'object') {
        if ('address' in v && v.address) return String(v.address);
        if ('name' in v && v.name) return String(v.name);
        if ('latitude' in v && 'longitude' in v) return `${v.latitude}, ${v.longitude}`;
        try { return JSON.stringify(v); } catch { return '[Object]'; }
      }
      return String(v);
    }

    return `<dl style="display:grid;grid-template-columns:1fr;gap:0.85rem;margin:0;">
      ${entries.map(([key, value]) => {
        const display = fmt(value);
        return `<div style="display:grid;grid-template-columns:120px 1fr;gap:0.6rem;align-items:start;">
          <dt style="font-size:0.7rem;color:var(--muted);text-transform:uppercase;letter-spacing:0.06em;padding-top:0.15rem;font-family:var(--mono);">${key}</dt>
          <dd style="margin:0;font-size:0.85rem;color:var(--fg);word-break:break-word;line-height:1.45;">${display}</dd>
        </div>`;
      }).join('')}
    </dl>`;
  }

  function initMap() {
    const mapContainer = document.getElementById('earth-map');
    if (!mapContainer) return;

    const markers = JSON.parse(mapContainer.dataset.markers || '[]');
    if (markers.length === 0) {
      mapContainer.innerHTML = '<div style="display:flex;align-items:center;justify-content:center;height:100%;color:var(--muted);font-size:0.9rem;font-family:var(--mono);">No geolocated records to display.</div>';
      return;
    }

    const avgLat = markers.reduce((s, m) => s + m.lat, 0) / markers.length;
    const avgLng = markers.reduce((s, m) => s + m.lng, 0) / markers.length;

    const map = new maplibregl.Map({
      container: mapContainer,
      style: {
        version: 8,
        sources: {
          osm: {
            type: 'raster',
            tiles: ['https://tile.openstreetmap.org/{z}/{x}/{y}.png'],
            tileSize: 256,
            attribution: '&copy; OpenStreetMap contributors',
          },
        },
        layers: [{ id: 'osm', type: 'raster', source: 'osm' }],
      },
      center: [avgLng || 0, avgLat || 20],
      zoom: markers.length === 1 ? 4 : 2,
    });

    map.addControl(new maplibregl.NavigationControl(), 'bottom-right');
    map.addControl(new maplibregl.FullscreenControl(), 'bottom-left');

    const bounds = new maplibregl.LngLatBounds();
    const panel = document.getElementById('map-panel');
    const panelContent = document.getElementById('map-panel-content');
    const panelClose = document.getElementById('map-panel-close');

    function getDescription(props) {
      return String(props['description'] ?? props['Description'] ?? props['Notes'] ?? props['notes'] ?? '');
    }

    function showPanel(m) {
      if (!panel || !panelContent) return;
      const desc = getDescription(m.properties);
      const descHtml = desc ? `<p style="font-size:1rem;color:var(--fg);line-height:1.6;margin:0 0 1.25rem 0;">${desc}</p>` : '';
      const propsHtml = renderProperties(m.properties);

      panelContent.innerHTML = `
        <h2 style="font-size:clamp(1.4rem, 3vw, 1.8rem);font-weight:500;margin:0 0 0.75rem 0;color:var(--fg);line-height:1.2;font-family:var(--serif);letter-spacing:-0.01em;">${m.name}</h2>
        ${descHtml}
        <div style="border-radius:var(--radius);border:1px solid var(--border);background:var(--card);padding:1.25rem;margin-bottom:1.25rem;">
          ${propsHtml}
        </div>
        <div style="display:flex;gap:0.75rem;flex-wrap:wrap;">
          <a href="${m.href}" style="display:inline-block;padding:0.55rem 1rem;border-radius:var(--radius);background:var(--primary);color:var(--primary-fg);font-size:0.8rem;text-decoration:none;font-family:var(--mono);text-transform:uppercase;letter-spacing:0.03em;">View full page →</a>
        </div>
      `;
      panel.style.display = 'block';
    }

    function hidePanel() {
      if (panel) panel.style.display = 'none';
    }

    panelClose?.addEventListener('click', hidePanel);
    panel?.addEventListener('click', (e) => e.stopPropagation());

    for (const m of markers) {
      const pinColor = m.caseStudy === 'Y' ? '#F0A030' : '#B0A090';
      const marker = new maplibregl.Marker({ color: pinColor, scale: 0.8 })
        .setLngLat([m.lng, m.lat])
        .addTo(map);

      marker.getElement().addEventListener('click', (e) => {
        e.stopPropagation();
        showPanel(m);
      });

      bounds.extend([m.lng, m.lat]);
    }

    if (markers.length > 1) {
      map.fitBounds(bounds, { padding: 40, maxZoom: 8 });
    }

    map.on('click', hidePanel);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initMap);
  } else {
    initMap();
  }
</script>
