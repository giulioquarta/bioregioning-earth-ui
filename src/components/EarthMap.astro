---
export interface Props {
  records?: Array<{
    id: string;
    properties: Record<string, any>;
    sectionRoute?: string;
  }>;
  basePath?: string;
}
const { records = [], basePath = '/' } = Astro.props;
const base = import.meta.env.BASE_URL;

const markers = records
  .filter((r) => {
    const lat = Number(r.properties['Lat'] ?? r.properties['lat'] ?? r.properties['Latitude']);
    const lng = Number(r.properties['Lng'] ?? r.properties['lng'] ?? r.properties['Longitude']);
    return !isNaN(lat) && !isNaN(lng);
  })
  .map((r) => {
    const lat = Number(r.properties['Lat'] ?? r.properties['lat'] ?? r.properties['Latitude']);
    const lng = Number(r.properties['Lng'] ?? r.properties['lng'] ?? r.properties['Longitude']);
    const name = String(r.properties['Name'] ?? r.properties['Title'] ?? 'Untitled');
    const slug = r.id.replace(/-/g, '');
    // If sectionRoute is provided (dashboard with mixed sections), use it. Otherwise use basePath.
    const pathPrefix = r.sectionRoute ? r.sectionRoute.replace(/\/$/, '') : basePath.replace(/\/$/, '');
    const link = `${base}${pathPrefix}/${slug}`;
    return { id: r.id, lat, lng, name, link };
  });
---

<div id="earth-map" style="width:100%;height:480px;border-radius:var(--radius);overflow:hidden;border:1px solid var(--border);" data-markers={JSON.stringify(markers)}></div>

<script>
  import maplibregl from 'maplibre-gl';
  import 'maplibre-gl/dist/maplibre-gl.css';

  function initMap() {
    const container = document.getElementById('earth-map');
    if (!container) return;

    const markers = JSON.parse(container.dataset.markers || '[]');
    if (markers.length === 0) {
      container.innerHTML = '<div style="display:flex;align-items:center;justify-content:center;height:100%;color:var(--muted);font-size:0.9rem;">No geolocated records to display.</div>';
      return;
    }

    // Compute center from markers
    const avgLat = markers.reduce((s, m) => s + m.lat, 0) / markers.length;
    const avgLng = markers.reduce((s, m) => s + m.lng, 0) / markers.length;

    const map = new maplibregl.Map({
      container,
      style: {
        version: 8,
        sources: {
          osm: {
            type: 'raster',
            tiles: ['https://tile.openstreetmap.org/{z}/{x}/{y}.png'],
            tileSize: 256,
            attribution: '&copy; OpenStreetMap contributors',
          },
        },
        layers: [{ id: 'osm', type: 'raster', source: 'osm' }],
      },
      center: [avgLng || 0, avgLat || 20],
      zoom: markers.length === 1 ? 4 : 2,
    });

    map.addControl(new maplibregl.NavigationControl(), 'top-right');
    map.addControl(new maplibregl.FullscreenControl(), 'top-left');

    const bounds = new maplibregl.LngLatBounds();

    for (const m of markers) {
      const el = document.createElement('div');
      el.style.cssText = 'width:14px;height:14px;border-radius:50%;background:var(--accent);border:2px solid white;box-shadow:0 2px 6px rgba(0,0,0,0.3);cursor:pointer;transition:transform 0.1s;';
      el.onmouseenter = () => { el.style.transform = 'scale(1.3)'; };
      el.onmouseleave = () => { el.style.transform = ''; };

      const popup = new maplibregl.Popup({ offset: 12, closeButton: false })
        .setHTML(`<a href="${m.link}" style="font-weight:600;font-size:0.9rem;color:var(--accent);text-decoration:none;">${m.name}</a>`);

      const marker = new maplibregl.Marker({ element: el })
        .setLngLat([m.lng, m.lat])
        .setPopup(popup)
        .addTo(map);

      bounds.extend([m.lng, m.lat]);
    }

    if (markers.length > 1) {
      map.fitBounds(bounds, { padding: 40, maxZoom: 8 });
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initMap);
  } else {
    initMap();
  }
</script>
