---
export interface Props {
  records?: Array<{
    id: string;
    properties: Record<string, any>;
    sectionRoute?: string;
  }>;
  basePath?: string;
}
const { records = [], basePath = '/' } = Astro.props;
const base = import.meta.env.BASE_URL;

function getCoords(props: Record<string, any>): { lat: number; lng: number } | null {
  // 1. Try Notion "location" type property (e.g. "Place", "Location")
  for (const key of Object.keys(props)) {
    const val = props[key];
    if (val && typeof val === 'object' && !Array.isArray(val)) {
      const hasLat = val.latitude != null && val.latitude !== '';
      const hasLng = val.longitude != null && val.longitude !== '';
      if (hasLat && hasLng) {
        const lat = Number(val.latitude);
        const lng = Number(val.longitude);
        if (!isNaN(lat) && !isNaN(lng)) return { lat, lng };
      }
    }
  }
  // 2. Fall back to raw Lat/Lng number properties (including location_lat / location_lng)
  const lat = Number(
    props['Lat'] ?? props['lat'] ?? props['Latitude'] ?? props['latitude'] ??
    props['location_lat'] ?? props['location_Lat'] ?? props['Location_Lat']
  );
  const lng = Number(
    props['Lng'] ?? props['lng'] ?? props['Longitude'] ?? props['longitude'] ??
    props['location_lng'] ?? props['location_Lng'] ?? props['Location_Lng']
  );
  if (!isNaN(lat) && !isNaN(lng) && (lat !== 0 || lng !== 0)) return { lat, lng };
  return null;
}

const markers = records
  .map((r) => {
    const coords = getCoords(r.properties);
    if (!coords) return null;
    const name = String(r.properties['Name'] ?? r.properties['Title'] ?? 'Untitled');
    const slug = r.id.replace(/-/g, '');
    const pathPrefix = r.sectionRoute ? r.sectionRoute.replace(/\/$/, '') : basePath.replace(/\/$/, '');
    const link = `${base}${pathPrefix}/${slug}`;
    return { id: r.id, lat: coords.lat, lng: coords.lng, name, link };
  })
  .filter(Boolean) as Array<{ id: string; lat: number; lng: number; name: string; link: string }>;
---

<div id="earth-map" style="width:100%;height:480px;border-radius:var(--radius);overflow:hidden;border:1px solid var(--border);" data-markers={JSON.stringify(markers)}></div>

<script>
  import maplibregl from 'maplibre-gl';
  import 'maplibre-gl/dist/maplibre-gl.css';

  function initMap() {
    const container = document.getElementById('earth-map');
    if (!container) return;

    const markers = JSON.parse(container.dataset.markers || '[]');
    if (markers.length === 0) {
      container.innerHTML = '<div style="display:flex;align-items:center;justify-content:center;height:100%;color:var(--muted);font-size:0.9rem;font-family:var(--mono);">No geolocated records to display.</div>';
      return;
    }

    const avgLat = markers.reduce((s, m) => s + m.lat, 0) / markers.length;
    const avgLng = markers.reduce((s, m) => s + m.lng, 0) / markers.length;

    const map = new maplibregl.Map({
      container,
      style: {
        version: 8,
        sources: {
          osm: {
            type: 'raster',
            tiles: ['https://tile.openstreetmap.org/{z}/{x}/{y}.png'],
            tileSize: 256,
            attribution: '&copy; OpenStreetMap contributors',
          },
        },
        layers: [{ id: 'osm', type: 'raster', source: 'osm' }],
      },
      center: [avgLng || 0, avgLat || 20],
      zoom: markers.length === 1 ? 4 : 2,
    });

    map.addControl(new maplibregl.NavigationControl(), 'top-right');
    map.addControl(new maplibregl.FullscreenControl(), 'top-left');

    const bounds = new maplibregl.LngLatBounds();

    for (const m of markers) {
      const el = document.createElement('div');
      // Use a flex wrapper so the tooltip can center without CSS transform (avoids MapLibre disappearing bug)
      el.style.cssText = 'width:max-content;min-width:14px;height:14px;display:flex;align-items:flex-end;justify-content:center;position:relative;cursor:pointer;';

      const dot = document.createElement('div');
      dot.style.cssText = 'width:14px;height:14px;border-radius:50%;background:var(--primary);border:2px solid var(--fg);box-shadow:0 2px 6px rgba(0,0,0,0.2);flex-shrink:0;';
      el.appendChild(dot);

      const tip = document.createElement('div');
      tip.textContent = m.name;
      tip.style.cssText = 'position:absolute;bottom:18px;left:0;right:0;width:max-content;margin:0 auto;background:var(--fg);color:var(--paper-50);padding:0.3rem 0.6rem;border-radius:var(--radius-sm);font-size:0.75rem;font-family:var(--sans);white-space:nowrap;pointer-events:none;opacity:0;transition:opacity 0.15s;z-index:30;';
      el.appendChild(tip);

      el.addEventListener('mouseenter', () => { tip.style.opacity = '1'; dot.style.borderColor = 'var(--primary)'; dot.style.background = 'var(--fg)'; });
      el.addEventListener('mouseleave', () => { tip.style.opacity = '0'; dot.style.borderColor = 'var(--fg)'; dot.style.background = 'var(--primary)'; });

      const popup = new maplibregl.Popup({ offset: 8, closeButton: false }).setHTML(
        `<a href="${m.link}" style="font-weight:600;font-size:0.9rem;color:var(--primary);text-decoration:none;font-family:var(--sans);">${m.name}</a>`
      );

      new maplibregl.Marker({ element: el })
        .setLngLat([m.lng, m.lat])
        .setPopup(popup)
        .addTo(map);

      bounds.extend([m.lng, m.lat]);
    }

    if (markers.length > 1) {
      map.fitBounds(bounds, { padding: 40, maxZoom: 8 });
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initMap);
  } else {
    initMap();
  }
</script>
